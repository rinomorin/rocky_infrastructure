vrrp_script check_haproxy {
    script "killall -0 haproxy"
    interval 2
    weight 2
}

vrrp_instance VI_1 {
    state {{ "MASTER" if inventory_hostname == groups['hahost'][0] else "BACKUP" }}
    interface enp3s0  # Ensure this matches your actual interface name (ip a)
    virtual_router_id 51
    priority {{ 101 if inventory_hostname == groups['hahost'][0] else 30 }}
    advert_int 1
    
    authentication {
        auth_type PASS
        auth_pass 42  # Keep this simple/consistent
    }

    virtual_ipaddress {
        {{ k8s_api_vip }}
    }

    track_script {
        check_haproxy
    }
}