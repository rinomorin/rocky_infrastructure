#!/bin/bash
# Ansible managed: K8s Init
set -e 

{% set master_node = groups['control_nodes'][0] %}
{% set master_ip = hostvars[master_node]['provision_ip'] %}
{% set master_short_name = hostvars[master_node]['hostname'].split('.')[0] %}

echo "--- Loading Kernel Modules ---"
modprobe overlay
modprobe br_netfilter

echo "--- Configuring Sysctl ---"
cat <<EOF | tee /etc/sysctl.d/k8s.conf
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
EOF
sysctl --system

echo "--- Managing Services ---"
systemctl disable --now firewalld || true
systemctl daemon-reload

# Determine service name (handles Rocky/RHEL variants)
if systemctl list-unit-files | grep -q "^cri-o.service"; then
    SVC_NAME="cri-o"
else
    SVC_NAME="crio"
fi

#systemctl stop $SVC_NAME || true
#systemctl start $SVC_NAME
#systemctl enable $SVC_NAME
#systemctl restart kubelet

echo "--- Validating Socket ---";
for i in {1..10}; do
    if [ -S /var/run/crio/crio.sock ]; then
        SOCK="unix:///var/run/crio/crio.sock"
        break
    elif [ -S /var/run/cri-o/cri-o.sock ]; then
        SOCK="unix:///var/run/cri-o/cri-o.sock"
        break
    fi
    sleep 1
done

if [ ! -f /etc/kubernetes/admin.conf ]; then
    echo "--- Initializing Cluster ---"
    kubeadm init \
      --control-plane-endpoint '{{ master_short_name }}:6443' \
      --upload-certs \
      --pod-network-cidr=10.244.0.0/16 \
      --apiserver-advertise-address={{ master_ip }} \
      --cri-socket ${SOCK:-unix:///var/run/crio/crio.sock} \
      --ignore-preflight-errors=Swap,SystemVerification
else
    echo "ALREADY_INITIALIZED"
fi