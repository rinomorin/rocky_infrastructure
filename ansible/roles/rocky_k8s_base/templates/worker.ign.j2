{
  "ignition": {
    "version": "3.4.0"
  },

  "storage": {
    "files": [
      {
        "path": "/etc/hostname",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;charset=utf-8,{{ inventory_hostname }}"
        }
      },
      {
        "path": "/etc/kubernetes/kubeadm-join.yaml",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;charset=utf-8,{{ kubeadm_join_config | urlencode }}"
        }
      },
      {
        "path": "/etc/crio/crio.conf.d/99-k8s.conf",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;charset=utf-8,{{ crio_config | urlencode }}"
        }
      },
      {
        "path": "/var/lib/kubelet/config.yaml",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;charset=utf-8,{{ kubelet_config | urlencode }}"
        }
      },
      {
        "path": "/etc/systemd/system/kubeadm-join.service",
        "mode": 420,
        "contents": {
          "source": "data:text/plain;charset=utf-8,[Unit]\nDescription=Kubeadm join\nAfter=network-online.target crio.service\nWants=network-online.target\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/kubeadm join --config=/etc/kubernetes/kubeadm-join.yaml\nRemainAfterExit=yes\n\n[Install]\nWantedBy=multi-user.target\n"
        }
      }
    ]
  },

  "systemd": {
    "units": [
      {
        "name": "crio.service",
        "enabled": true
      },
      {
        "name": "kubelet.service",
        "enabled": true
      },
      {
        "name": "kubeadm-join.service",
        "enabled": true
      }
    ]
  }
}
